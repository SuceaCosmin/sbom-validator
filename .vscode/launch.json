{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SBOM Validator: validate file",
            "type": "debugpy",
            "request": "launch",
            "module": "sbom_validator.cli",
            "args": ["validate", "${input:sbomFile}"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "SBOM Validator: validate (strict mode)",
            "type": "debugpy",
            "request": "launch",
            "module": "sbom_validator.cli",
            "args": ["validate", "--strict", "${input:sbomFile}"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "SBOM Validator: validate open file",
            "type": "debugpy",
            "request": "launch",
            "module": "sbom_validator.cli",
            "args": ["validate", "${file}"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Tests: all",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests", "--tb=short", "-v"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Tests: unit only",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/unit", "--tb=short", "-v"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Tests: integration only",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/integration", "--tb=short", "-v"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Tests: current file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "--tb=short", "-v"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Tests: with coverage",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests",
                "--tb=short",
                "-v",
                "--cov=sbom_validator",
                "--cov-report=term-missing"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "sbomFile",
            "type": "promptString",
            "description": "Path to the SBOM file to validate",
            "default": "tests/fixtures/spdx/valid-minimal.spdx.json"
        }
    ]
}
