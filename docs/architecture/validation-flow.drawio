        <mxCell id="e-nfail-exit1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="result-ntia-fail" target="exit-1b" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PASS path -->
        <mxCell id="result-pass" value="ValidationResult(PASS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="1230" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-dec-pass" value="No (none)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#007700;fontStyle=1;fontSize=12;" edge="1" source="dec-ntia" target="result-pass" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Exit 0 -->
        <mxCell id="exit-0" value="Exit code &lt;b&gt;0&lt;/b&gt; (PASS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="1310" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-pass-exit0" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="result-pass" target="exit-0" parent="1">
