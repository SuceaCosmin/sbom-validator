        <mxCell id="e-ntia-issues" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-ntia" target="step-ntia-result" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision: NTIA issues found? -->
        <mxCell id="dec-ntia" value="NTIA&lt;br&gt;issues?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
