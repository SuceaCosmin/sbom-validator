  <diagram id="validation-flow" name="Validation Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TITLE                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="title" value="sbom-validator: Validation Flow (CLI → Exit Code)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- STEP 1 – User + CLI                                -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Actor: User -->
        <mxCell id="actor-user" value="User" style="shape=mxgraph.flowchart.start_2;fillColor=#f0f0f0;strokeColor=#666666;fontSize=13;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="505" y="80" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Step 1: User runs command -->
        <mxCell id="step-cmd" value="sbom-validator validate file.json [--format text|json]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="160" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-user-cmd" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="actor-user" target="step-cmd" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 2: CLI receives input, calls validator.validate(path) -->
        <mxCell id="step-cli" value="CLI receives input&lt;br&gt;calls &lt;b&gt;validator.validate(path)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="240" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-cmd-cli" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-cmd" target="step-cli" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: format_detector.detect_format(path) -->
        <mxCell id="step-detect" value="format_detector.detect_format(path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="330" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-cli-detect" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-cli" target="step-detect" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision: Format known? -->
        <mxCell id="dec-format" value="Format&lt;br&gt;recognized?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="e-detect-dec" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-detect" target="dec-format" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── ORANGE PATH: format unknown ── -->
        <!-- ValidationResult(ERROR) -->
        <mxCell id="result-error" value="ValidationResult(ERROR)&lt;br&gt;&lt;font color='#cc3300'&gt;Unrecognized format&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="435" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-dec-error" value="No (unknown)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontColor=#d79b00;fontStyle=1;fontSize=12;" edge="1" source="dec-format" target="result-error" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Exit 2 -->
        <mxCell id="exit-2" value="Exit code &lt;b&gt;2&lt;/b&gt; (ERROR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;arcSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="530" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-error-exit2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="result-error" target="exit-2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── MAIN PATH: format known → Stage 1 ── -->
        <!-- Step 5: schema_validator.validate_schema -->
        <mxCell id="step-schema" value="schema_validator.validate_schema(raw_doc, format)&lt;br&gt;&lt;font color='#666666'&gt;Stage 1 — Schema Validation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="355" y="550" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-dec-schema" value="Yes (known)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#007700;fontStyle=1;fontSize=12;" edge="1" source="dec-format" target="step-schema" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision: Schema valid? -->
        <mxCell id="dec-schema" value="Schema&lt;br&gt;valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="430" y="640" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="e-schema-dec" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-schema" target="dec-schema" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Schema FAIL path -->
        <mxCell id="result-schema-fail" value="ValidationResult(FAIL)&lt;br&gt;&lt;font color='#cc3300'&gt;Schema issues reported&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="655" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-dec-sfail" value="Invalid" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontColor=#b85450;fontStyle=1;fontSize=12;" edge="1" source="dec-schema" target="result-schema-fail" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Exit 1 (schema fail) -->
        <mxCell id="exit-1a" value="Exit code &lt;b&gt;1&lt;/b&gt; (FAIL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;arcSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="750" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-sfail-exit1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="result-schema-fail" target="exit-1a" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── MAIN PATH: schema valid → parse ── -->
        <!-- Step 7: Parser call (SPDX or CycloneDX) -->
        <mxCell id="step-parse" value="Call parser:&lt;br&gt;&lt;b&gt;parse_spdx(raw_doc)&lt;/b&gt; or &lt;b&gt;parse_cyclonedx(raw_doc)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="355" y="765" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-dec-parse" value="Valid" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#007700;fontStyle=1;fontSize=12;" edge="1" source="dec-schema" target="step-parse" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 8: Parser returns NormalizedSBOM -->
        <mxCell id="step-normalized" value="Parser returns &lt;b&gt;NormalizedSBOM&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="855" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e-parse-norm" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-parse" target="step-normalized" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 9: ntia_checker.check_ntia -->
        <mxCell id="step-ntia" value="ntia_checker.check_ntia(normalized_sbom)&lt;br&gt;&lt;font color='#666666'&gt;Stage 2 — NTIA Element Checks (FR-04 to FR-10)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="935" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e-norm-ntia" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="step-normalized" target="step-ntia" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 10: NTIA returns list of issues -->
        <mxCell id="step-ntia-result" value="NTIA checker returns &lt;b&gt;list[ValidationIssue]&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="1025" width="320" height="50" as="geometry" />
